{
  "manifest_version": 3,
  "name": "PeekUI",
  "version": "1.0",
  "description": "Inspect CSS properties with a modern, minimalist UI.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "Activate Inspector"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "inject.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "inject.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}